---
import navigation from "../content/settings/navigation.json";

const currentPath = Astro.url.pathname;
const isActive = (href: string) => {
  // Handle both /path and /path/ variations
  const normalizedHref = href.replace(/\/$/, "") || "/";
  const normalizedPath = currentPath.replace(/\/$/, "") || "/";

  // Exact match for home
  if (normalizedHref === "/") {
    return normalizedPath === "/";
  }

  // For other pages, match if current path starts with href (handles nested routes)
  return (
    normalizedPath === normalizedHref ||
    normalizedPath.startsWith(normalizedHref + "/")
  );
};
---

<div id="main-menu" class="nav-links">
  {
    navigation.main.map((link) => (
      <a
        href={link.href}
        class:list={[{ active: isActive(link.href) }]}
        aria-current={isActive(link.href) ? "page" : undefined}
      >
        {link.label}
      </a>
    ))
  }
</div>

<style>
  .nav-links a.active {
    font-weight: bold;
    color: var(--color-primary);
    text-decoration: underline;
  }
</style>
